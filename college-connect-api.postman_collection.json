{
  "info": {
    "name": "College Connect API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "branchId",
      "value": ""
    },
    {
      "key": "announcementId",
      "value": ""
    },
    {
      "key": "materialId",
      "value": ""
    },
    {
      "key": "questionId",
      "value": ""
    },
    {
      "key": "answerId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "year",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Public Announcements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/public/announcements"
          }
        },
        {
          "name": "Get Public Branches",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/public/branches"
          }
        },
        {
          "name": "Get Public Academic Years",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/public/academic-years"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Student Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/signup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@example.com\",\n  \"password\": \"123456\",\n  \"branchId\": \"{{branchId}}\",\n  \"year\": {{year}}\n}"
            }
          }
        },
        {
          "name": "Student Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/admin/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/profile",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/users/profile",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Student\",\n  \"bio\": \"I love helping classmates.\",\n  \"profileImage\": \"https://example.com/avatar.png\"\n}"
            }
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/dashboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Branch",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/branches",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Computer Science and Engineering\",\n  \"code\": \"CSE\",\n  \"totalYears\": 4\n}"
            }
          }
        },
        {
          "name": "Get Branches",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/branches",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ]
          }
        },
        {
          "name": "Update Branch",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/admin/branches/{{branchId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Computer Science\",\n  \"code\": \"CSE\",\n  \"totalYears\": 4\n}"
            }
          }
        },
        {
          "name": "Update Branch Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/admin/branches/{{branchId}}/status",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Create Academic Year",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/academic-years",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"yearNumber\": 1,\n  \"label\": \"First Year\"\n}"
            }
          }
        },
        {
          "name": "Get Academic Years",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/academic-years",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ]
          }
        },
        {
          "name": "Update User Section",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/admin/users/{{userId}}/section",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"currentYear\": {{year}}\n}"
            }
          }
        },
        {
          "name": "Promote Students",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/promote-students",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"force\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Announcements",
      "item": [
        {
          "name": "Get Announcements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/announcements",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Create Announcement",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/announcements",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Exam Schedule\",\n  \"content\": \"Mid-semester exams start next Monday.\",\n  \"visibility\": \"public\",\n  \"branchId\": \"{{branchId}}\",\n  \"year\": {{year}},\n  \"isPinned\": true\n}"
            }
          }
        },
        {
          "name": "Update Announcement",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/announcements/{{announcementId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Exam Schedule\",\n  \"content\": \"Exams begin on Tuesday instead.\",\n  \"visibility\": \"public\",\n  \"isPinned\": false\n}"
            }
          }
        },
        {
          "name": "Delete Announcement",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/announcements/{{announcementId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/chat/messages?branchId={{branchId}}&year={{year}}&page=1&limit=50",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Create Message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/chat/messages",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"year\": {{year}},\n  \"content\": \"Hello section!\",\n  \"type\": \"text\",\n  \"fileUrl\": \"\",\n  \"fileName\": \"\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Materials",
      "item": [
        {
          "name": "Upload Material",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/materials",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "DBMS Notes Unit 1",
                  "type": "text"
                },
                {
                  "key": "subject",
                  "value": "DBMS",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Important notes for unit 1",
                  "type": "text"
                },
                {
                  "key": "branchId",
                  "value": "{{branchId}}",
                  "type": "text"
                },
                {
                  "key": "year",
                  "value": "{{year}}",
                  "type": "text"
                },
                {
                  "key": "semester",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "file",
                  "src": "",
                  "type": "file"
                }
              ]
            }
          }
        },
        {
          "name": "Get Materials",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/materials?branchId={{branchId}}&year={{year}}&subject=DBMS",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Material By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/materials/{{materialId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Delete Material",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/materials/{{materialId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "Create Question",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/questions",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"What is normalization?\",\n  \"description\": \"Please explain 1NF, 2NF, and 3NF with examples.\",\n  \"branchId\": \"{{branchId}}\",\n  \"year\": {{year}},\n  \"tags\": [\"dbms\", \"normalization\"]\n}"
            }
          }
        },
        {
          "name": "Get Questions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/questions?branchId={{branchId}}&year={{year}}&resolved=false",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Question By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/questions/{{questionId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Add Answer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/questions/{{questionId}}/answers",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Normalization organizes data to reduce redundancy and improve integrity.\"\n}"
            }
          }
        },
        {
          "name": "Upvote Answer",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/questions/answers/{{answerId}}/upvote",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        },
        {
          "name": "Accept Answer",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/questions/answers/{{answerId}}/accept",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/leaderboard?scope=global",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ]
          }
        }
      ]
    }
  ]
}